{
  "manifest_version": 3,
  "name": "WordVault",
  "version": "1.0.0",
  "description": "Save and learn new words as you browse",
  "permissions": [
    "activeTab",
    "storage",
    "contextMenus"
  ],
  "icons": {
    "16": "icons/word-vault-icon.jpg",
    "48": "icons/word-vault-icon.jpg",
    "128": "icons/word-vault-icon.jpg"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/word-vault-icon.jpg",
      "48": "icons/word-vault-icon.jpg",
      "128": "icons/word-vault-icon.jpg"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "host_permissions": [
    "https://herman-cognisable-intensely.ngrok-free.dev/*",
    "http://localhost:3006/*",
    "https://wordvault-api.onrender.com/*"
  ],
  "web_accessible_resources": [{
    "resources": ["dashboard.html", "lookup.html", "vault.html", "settings.html"],
    "matches": ["<all_urls>"]
  }]
}